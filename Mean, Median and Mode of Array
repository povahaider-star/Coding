#include <iostream>
using namespace std;

void sortArray(int arr[], int n)
{
    for(int i = 0; i < n - 1; i++)
    {
        for(int j = i + 1; j < n; j++)
        {
            if(arr[i] > arr[j])
            {
                int temp = arr[i];
                arr[i] = arr[j];
                arr[j] = temp;
            }
        }
    }
}

double mean(int arr[], int n)
{
    int sum = 0;

    for(int i = 0; i < n; i++)
    {
        sum += arr[i];
    }

    return (double)sum / n;
}

double median(int arr[], int n)
{
    sortArray(arr, n);

    if(n % 2 == 0)
    {
        return (arr[n/2] + arr[(n/2)-1]) / 2.0;
    }
    else
    {
        return arr[n/2];
    }
}

int mode(int arr[], int n)
{
    int maxCount = 0;
    int mode = arr[0];

    for(int i = 0; i < n; i++)
    {
        int count = 1;

        for(int j = i + 1; j < n; j++)
        {
            if(arr[i] == arr[j])
            {
                count++;
            }
        }

        if(count > maxCount)
        {
            maxCount = count;
            mode = arr[i];
        }
    }

    cout << "Mode   : " << mode << " appeared " << maxCount << " times\n";

    return mode;
}

int main()
{
    int arr[] = {34, 56, 34, 23, 13, 45, 34, 78, 55, 99};

    int n = 10;

    cout << "Array is : ";

    for(int i = 0; i < n; i++)
    {
        cout << arr[i] << " ";
    }

    cout << endl;

    cout << "Mean   : " << mean(arr, n) << endl;
    cout << "Median : " << median(arr, n) << endl;

    mode(arr, n);

    return 0;
}
