#include <iostream>
using namespace std;

int main()
{
    char ch;

    int characters = 0;
    int spaces = 0;
    int tabs = 0;
    int lines = 0;

    cout << "Enter a string: (Add '*' at the end of input)\n";

    while(cin.get(ch))
    {
        if(ch == '*')
            break;

        characters++;

        if(ch == ' ')
            spaces++;

        if(ch == '\t')
            tabs++;

        if(ch == '\n')
            lines++;
    }

    cout << "\nCharacters : " << characters << endl;
    cout << "Spaces     : " << spaces << endl;
    cout << "Tabs       : " << tabs << endl;
    cout << "Lines      : " << lines << endl;

    return 0;
}
